{
  "datasetVersion": {
    "license": {
      "name": "{{ dataset.license.name }}",
      "uri": "{{ dataset.license.uri }}"
    },
    "protocol": "{{ dataset.protocol }}",
    "authority": "{{ dataset.authority }}",
    "identifier": "{{ dataset.identifier }}",
    "metadataBlocks": {

      "citation": {
        "displayName": "{{ dataset.citation.display_name }}",
        "fields": [
            {"title":"{{ dataset.citation.title }}"},
            {"subtitle":"{{ dataset.citation.subtitle }}"},
            {"alternativeURL" :"{{ dataset.citation.alternative_url }}"},
            {"otherId" : [
              {% for id in dataset.citation.other_id %}
              {
                "otherIdAgency": "{{ id.agency }}",
                "otherIdValue": "{{ id.value }}"
              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ]},

            {"author" : [
              {% for author in dataset.citation.author %}
                {
                  "authorName": "{{ author.author_name }}",
                  "authorAffiliation": "{{ author.author_affiliation }}"
                }

              {% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },

          {"datasetContact" : [
              {% for contact in dataset.citation.dataset_contact %}
                {
                    "datasetContactName":"{{ contact.contact_name }}",
                    "datasetContactEmail":"{{ contact.contact_email }}"
                }
              {% if not loop.last %},{% endif %}
              {% endfor %}
            ]
            },

          {"dsDescription" : [
              {% for desc in dataset.citation.dataset_description %}
              {
                "dsDescriptionValue": "{{ desc.description }}",
                "dsDescriptionDate": "{{ desc.description_date }}"
              }
              {% if not loop.last %},{% endif %}
              {% endfor %}
            ]
            },

          {"subject": [
              {% for subject in dataset.citation.subject %}
              "{{ subject }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
            },

          {"language": [
              {% for language in dataset.citation.language %}
              "{{ language }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          }

        ]
      },

      "geospatial": {
        "fields": [
            {"geographicUnit": [
              {% for item in dataset.geospatial.geographic_unit %}
              "{{ item }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]}

          {% if dataset.geospatial.geographic_bounding_box %}
          ,{"geographicBoundingBox": [
                {"westLongitude": "{{ dataset.geospatial.geographic_bounding_box.west }}"},
                {"eastLongitude": "{{ dataset.geospatial.geographic_bounding_box.east }}"},
                {"northLatitude": "{{ dataset.geospatial.geographic_bounding_box.north }}"},
                {"southLatitude": "{{ dataset.geospatial.geographic_bounding_box.south }}"}
              ]
           }
          {% endif %}
        ]
      },

      "customCAFEDataSources": {
        "fields": [
          {"cafeDerivedFromExistingDataset": "{{ dataset.cafe_custom.derived_from_existing_dataset }}"},
          {"cafeSourceDataUrl":"{{ dataset.cafe_custom.source_data_url }}"},
          {"cafeSourceDataTitle":"{{ dataset.cafe_custom.source_data_title }}"},
          {"cafeSourceDataAuthor":[
              {% for item in dataset.cafe_custom.source_data_author %}
              "{{ item }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          }
        ]
      }
    }

    {% if dataset.files|length > 0 %}
        ,
        "files": [
          {% for file in dataset.files %}
              {
                "description": "{{ file.description }}",
                "label": "{{ file.label }}",
                "restricted": {{ file.restricted | lower }},
                "version": {{ file.version }},
                "datasetVersionId": {{ file.dataset_version_id }},
                "dataFile": {
                  "id": {{ file.id }},
                  "filename": "{{ file.filename }}",
                  "contentType": "{{ file.content_type }}",
                  "filesize": {{ file.filesize }},
                  "description": "{{ file.description }}",
                  "storageIdentifier": "{{ file.storage_identifier }}",
                  "originalFormatLabel": "{{ file.original_format_label }}",
                  "rootDataFileId": {{ file.root_data_file_id }},
                  "checksum": {
                    "type": "{{ file.checksum_type }}",
                    "value": "{{ file.checksum_value }}"
                  }
                }
          {% if not loop.last %},{% endif %}
          {% endfor %}
        ]
    {% endif %}
  }
}









  "customCAFEDataLocation": {
          "displayName": "Metadata About Geospatial Files",
          "fields": [
            {
              "typeName": "cafeIncludesGeospatialFile",
              "multiple": false,
              "typeClass": "controlledVocabulary",
              "value": "{{ dataset.cafe_custom.includes_geospatial_file }}"
            },
            {
              "typeName": "cafeSpatialReferenceSystem",
              "multiple": false,
              "typeClass": "compound",
              "value": [
                {
                  "cafeSpatialReferenceSystemName": {
                    "typeName": "cafeSpatialReferenceSystemName",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ dataset.cafe_location.spatial_reference_system.name }}"
                  },
                  "cafeSpatialReferenceSystemURL": {
                    "typeName": "cafeSpatialReferenceSystemURL",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ dataset.cafe_location.spatial_reference_system.url }}"
                  }
                }
              ]
            },
            {
              "typeName": "cafeSpatialFileType",
              "multiple": false,
              "typeClass": "controlledVocabulary",
              "value": "{{ dataset.cafe_location.spatial_file_type }}"
            },
            {
              "typeName": "cafeSpatialFileTypeOther",
              "multiple": false,
              "typeClass": "primitive",
              "value": "{{ dataset.cafe_location.spatial_file_type_other }}"
            },
            {
              "typeName": "cafeSpatialResolution",
              "multiple": false,
              "typeClass": "compound",
              "value": [
                {
                  "cafeSpatialResolutionValue": {
                    "typeName": "cafeSpatialResolutionValue",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ dataset.cafe_location.spatial_resolution.value }}"
                  },
                  "cafeSpatialResolutionUnit": {
                    "typeName": "cafeSpatialResolutionUnit",
                    "multiple": false,
                    "typeClass": "controlledVocabulary",
                    "value": "{{ dataset.cafe_location.spatial_resolution.unit }}"
                  },
                  "cafeSpatialResolutionUnitOther": {
                    "typeName": "cafeSpatialResolutionUnitOther",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ dataset.cafe_location.spatial_resolution.unit_other }}"
                  }
                }
              ]
            }
    ]
    },
