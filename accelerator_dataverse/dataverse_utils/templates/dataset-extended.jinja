{
  "datasetVersion": {
    "license": {
      "name": "{{ dataset.license.name }}",
      "uri": "{{ dataset.license.uri }}"
    },
    "protocol": "{{ dataset.protocol }}",
    "authority": "{{ dataset.authority }}",
    "identifier": "{{ dataset.identifier }}",
    "metadataBlocks": {
      "citation": {

        "displayName": "{{ dataset.citation.display_name }}",

        "fields": [
          {
            "typeName": "title",
            "multiple": false,
            "value": "{{ dataset.citation.title }}",
            "typeClass": "primitive"
          },
          {
            "typeName": "subtitle",
            "multiple": false,
            "typeClass": "primitive",
            "value": "{{ dataset.citation.subtitle }}"
          },
          {
            "typeName": "alternativeTitle",
            "multiple": true,
            "typeClass": "primitive",
            "value": [{% for title in dataset.citation.alternative_title %}
                {{ title }}
              {% if not loop.last %},{% endif %}
              {% endfor %}]
          },
            {
            "typeName": "alternativeURL",
            "multiple": false,
            "typeClass": "primitive",
            "value": "{{  dataset.citation.alternative_url }}"
          },

          {
            "typeName": "otherId",
            "multiple": true,
            "typeClass": "compound",
            "value": [

              {% for id in dataset.citation.other_id %}

                  {
                    "otherIdAgency": {
                      "typeName": "otherIdAgency",
                      "multiple": false,
                      "typeClass": "primitive",
                      "value": "{{ id.agency }}"
                    },
                    "otherIdValue": {
                      "typeName": "otherIdValue",
                      "multiple": false,
                      "typeClass": "primitive",
                      "value": "{{ id.value }}"
                    }
              }


                  {% if not loop.last %},{% endif %}
              {% endfor %}

            ]
          },


          {
            "typeName": "author",
            "multiple": true,
            "value": [
              {% for author in dataset.citation.author %}
              {
                "authorName": {
                  "typeName": "authorName",
                  "multiple": false,
                  "value": "{{ author.author_name }}",
                  "typeClass": "primitive"
                },
                "authorAffiliation": {
                  "typeName": "authorAffiliation",
                  "multiple": false,
                  "value": "{{ author.author_affiliation }}",
                  "typeClass": "primitive"
                },
                "authorIdentifierScheme": {
                  "typeName": "authorIdentifierScheme",
                  "multiple": false,
                  "typeClass": "controlledVocabulary",
                  "value": "{{ author.author_identifier_scheme }}"
                },
                "authorIdentifier": {
                  "typeName": "authorIdentifier",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ author.author_identifier }}"
                }
              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ],
            "typeClass": "compound"
            },


            {
            "typeName": "datasetContact",
            "multiple": true,
            "value": [
              {% for contact in dataset.citation.dataset_contact %}
              {
                "datasetContactName": {
                  "typeName": "datasetContactName",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ contact.contact_name }}"
                },

                  "datasetContactAffiliation": {
                  "typeName": "datasetContactAffiliation",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{  contact.contact_affiliation }}"
                },
                "datasetContactEmail": {
                  "typeName": "datasetContactEmail",
                  "multiple": false,
                  "value": "{{ contact.contact_email }}",
                  "typeClass": "primitive"
                }

              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ],
            "typeClass": "compound"
          },

          {
            "typeName": "dsDescription",
            "multiple": true,
            "value": [
              {% for desc in dataset.citation.dataset_description %}
              {
                "dsDescriptionValue": {
                  "typeName": "dsDescriptionValue",
                  "multiple": false,
                  "value": "{{ desc.description }}",
                  "typeClass": "primitive"
                },
                  "dsDescriptionDate": {
                  "typeName": "dsDescriptionDate",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ desc.description_date }}"
                }
              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ],
            "typeClass": "compound"
          },

          {
            "typeName": "subject",
            "multiple": true,
            "value": [{% for subject in dataset.citation.subject %}"{{ subject }}"{% if not loop.last %}, {% endif %}{% endfor %}],
            "typeClass": "controlledVocabulary"
          },

          {
            "typeName": "keyword",
            "multiple": true,
            "typeClass": "compound",
            "value": [

             {% for keyword in dataset.citation.keyword %}

              {
                "keywordValue": {
                  "typeName": "keywordValue",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ keyword.keyword }}"
                },
                "keywordTermURI": {
                  "typeName": "keywordTermURI",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ keyword.keyword_uri }}"
                },
                "keywordVocabulary": {
                  "typeName": "keywordVocabulary",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ keyword.vocabulary }}"
                },
                "keywordVocabularyURI": {
                  "typeName": "keywordVocabularyURI",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ keyword.vocabulary_uri }}"
                }
              }

                 {% if not loop.last %},{% endif %}
              {% endfor %}

            ]
          },

          {
            "typeName": "topicClassification",
            "multiple": true,
            "typeClass": "compound",
            "value": [

                {% for topic in dataset.citation.topic_classification %}

              {
                "topicClassValue": {
                  "typeName": "topicClassValue",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ topic.name }}"
                },
                "topicClassVocab": {
                  "typeName": "topicClassVocab",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ topic.vocabulary }}"
                },
                "topicClassVocabURI": {
                  "typeName": "topicClassVocabURI",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ topic.vocabulary_uri }}"
                }
              }

                 {% if not loop.last %},{% endif %}
              {% endfor %}

            ]
          },

          {
            "typeName": "publication",
            "multiple": true,
            "typeClass": "compound",
            "value": [

                {% for publication in dataset.citation.publication %}


              {
                "publicationRelationType" : {
                  "typeName" : "publicationRelationType",
                  "multiple" : false,
                  "typeClass" : "controlledVocabulary",
                  "value" : "{{ publication.publication_relation_type }}"
                },
                "publicationCitation": {
                  "typeName": "publicationCitation",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ publication.citation }}"
                },
                "publicationIDType": {
                  "typeName": "publicationIDType",
                  "multiple": false,
                  "typeClass": "controlledVocabulary",
                  "value": "{{ publication.id_type }}"
                },
                "publicationIDNumber": {
                  "typeName": "publicationIDNumber",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ publication.id_number }}"
                },
                "publicationURL": {
                  "typeName": "publicationURL",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ publication.url }}"
                }
              }

                {% if not loop.last %},{% endif %}
              {% endfor %}


            ]
          },

         {
            "typeName": "notesText",
            "multiple": false,
            "typeClass": "primitive",
            "value": "{{ dataset.citation.notes_text }}"
          },

          {
            "typeName": "language",
            "multiple": true,
            "typeClass": "controlledVocabulary",
            "value": [

                 {% for language in dataset.citation.language %}
                     "{{ language }}"
                     {% if not loop.last %},{% endif %}
              {% endfor %}

            ]
          },


          {
            "typeName": "producer",
            "multiple": true,
            "typeClass": "compound",
            "value": [

              {% for producer in dataset.citation.producer %}

              {
                "producerName": {
                  "typeName": "producerName",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ producer.name }}"
                },
                "producerAffiliation": {
                  "typeName": "producerAffiliation",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ producer.affiliation }}"
                },
                "producerAbbreviation": {
                  "typeName": "producerAbbreviation",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ producer.abbreviation }}"
                },
                "producerURL": {
                  "typeName": "producerURL",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ producer.url }}"
                },
                "producerLogoURL": {
                  "typeName": "producerLogoURL",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ producer.logo_url }}"
                }
              }

              {% if not loop.last %},{% endif %}
              {% endfor %}

            ]
          },

          {
            "typeName": "productionDate",
            "multiple": false,
            "value": "{{ dataset.citation.production_date }}",
            "typeClass": "primitive"
          },

          {
            "typeName": "productionPlace",
            "multiple": true,
            "typeClass": "primitive",
            "value": [
                  {% for place in dataset.citation.production_place %}
                     "{{ place }}"
                      {% if not loop.last %},{% endif %}
                  {% endfor %}
            ]
          },


          {
            "typeName": "contributor",
            "multiple": true,
            "typeClass": "compound",
            "value": [

                {% for contributor in dataset.citation.contributor %}

              {
                "contributorType": {
                  "typeName": "contributorType",
                  "multiple": false,
                  "typeClass": "controlledVocabulary",
                  "value": "{{ contributor.type }}"
                },
                "contributorName": {
                  "typeName": "contributorName",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ contributor.name }}"
                }
              }
                   {% if not loop.last %},{% endif %}
                  {% endfor %}

            ]
          },


           {
            "typeName": "grantNumber",
            "multiple": true,
            "typeClass": "compound",
            "value": [

              {% for grant in dataset.citation.grant %}


              {
                "grantNumberAgency": {
                  "typeName": "grantNumberAgency",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ grant.agency }}"
                },
                "grantNumberValue": {
                  "typeName": "grantNumberValue",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ grant.number }}"
                }
              }

                 {% if not loop.last %},{% endif %}
                  {% endfor %}


            ]
          },


          {
            "typeName": "distributor",
            "multiple": true,
            "typeClass": "compound",
            "value": [

                {% for distributor in dataset.citation.distributor %}


              {
                "distributorName": {
                  "typeName": "distributorName",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ distributor.name }}"
                },
                "distributorAffiliation": {
                  "typeName": "distributorAffiliation",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ distributor.affiliation }}"
                },
                "distributorAbbreviation": {
                  "typeName": "distributorAbbreviation",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ distributor.abbreviation }}"
                },
                "distributorURL": {
                  "typeName": "distributorURL",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ distributor.url }}"
                },
                "distributorLogoURL": {
                  "typeName": "distributorLogoURL",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ distributor.logo_url }}"
                }
              }

                    {% if not loop.last %},{% endif %}
                  {% endfor %}


            ]
          },
           {
            "typeName": "distributionDate",
            "multiple": false,
            "typeClass": "primitive",
            "value": "{{ dataset.citation.distibution_date }}"
          },

          {
            "typeName": "depositor",
            "multiple": false,
            "value": "{{ dataset.citation.depositor }}",
            "typeClass": "primitive"
          },

          {
            "typeName": "dateOfDeposit",
            "multiple": false,
            "typeClass": "primitive",
            "value": "{{ dataset.citation.date_of_deposit }}"
          },














    {% if dataset.files %}
    ,
    "files": [
      {% for file in dataset.files %}
      {
        "description": "{{ file.description }}",
        "label": "{{ file.label }}",
        "restricted": {{ file.restricted | lower }},
        "version": {{ file.version }},
        "datasetVersionId": {{ file.dataset_version_id }},
        "dataFile": {
          "id": {{ file.id }},
          "filename": "{{ file.filename }}",
          "contentType": "{{ file.content_type }}",
          "filesize": {{ file.filesize }},
          "description": "{{ file.description }}",
          "storageIdentifier": "{{ file.storage_identifier }}",
          "originalFormatLabel": "{{ file.original_format_label }}",
          "rootDataFileId": {{ file.root_data_file_id }},
          "checksum": {
            "type": "{{ file.checksum_type }}",
            "value": "{{ file.checksum_value }}"
          }
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
    {% endif %}
  }
}
