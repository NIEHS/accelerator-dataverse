{
  "datasetVersion": {
    "license": {
      "name": "{{ dataset.license.name }}",
      "uri": "{{ dataset.license.uri }}"
    },
    "protocol": "{{ dataset.protocol }}",
    "authority": "{{ dataset.authority }}",
    "identifier": "{{ dataset.identifier }}",
    "metadataBlocks": {

      "citation": {
        "displayName": "Citation Metadata",
        "fields": [
          {
            "typeName": "title",
            "multiple": false,
            "typeClass": "primitive",
            "value": "{{ dataset.citation.title }}"
          },
         {% if dataset.citation.subtitle %}
         {
            "typeName": "subtitle",
            "multiple": false,
            "typeClass": "primitive",
            "value": "{{ dataset.citation.subtitle }}"
         },
         {% endif %}
         {% if dataset.citation.alternative_title %}
         {
            "typeName": "alternativeTitle",
            "multiple": true,
            "typeClass": "primitive",
            "value": [
              {% for alt in dataset.citation.alternative_title %}
              "{{ alt }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
         },
         {% endif %}
          {
            "typeName": "alternativeURL",
            "multiple": false,
            "typeClass": "primitive",
            "value": "{{ dataset.citation.alternative_url }}"
          },
          {
            "typeName": "otherId",
            "multiple": true,
            "typeClass": "compound",
            "value": [
              {% for id in dataset.citation.other_id %}
              {
                "otherIdAgency": {
                  "typeName": "otherIdAgency",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ id.agency }}"
                },
                "otherIdValue": {
                  "typeName": "otherIdValue",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ id.value }}"
                }
              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {
            "typeName": "author",
            "multiple": true,
            "typeClass": "compound",
            "value": [
              {% for author in dataset.citation.author %}
              {
                "authorName": {
                  "typeName": "authorName",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ author.author_name }}"
                },
                "authorAffiliation": {
                  "typeName": "authorAffiliation",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ author.author_affiliation }}"
                }
                {% if author.author_identifier_scheme %},
                "authorIdentifierScheme": {
                  "typeName": "authorIdentifierScheme",
                  "multiple": false,
                  "typeClass": "controlledVocabulary",
                  "value": "{{ author.author_identifier_scheme }}"
                }
                {% endif %}
                {% if author.author_identifier %},
                "authorIdentifier": {
                  "typeName": "authorIdentifier",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ author.author_identifier }}"
                }
                {% endif %}
              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {
            "typeName": "datasetContact",
            "multiple": true,
            "typeClass": "compound",
            "value": [
              {% for contact in dataset.citation.dataset_contact %}
              {
                "datasetContactName": {
                  "typeName": "datasetContactName",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ contact.contact_name }}"
                }
                {% if contact.contact_affiliation %},
                "datasetContactAffiliation": {
                  "typeName": "datasetContactAffiliation",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ contact.contact_affiliation }}"
                }
                {% endif %}
                ,
                "datasetContactEmail": {
                  "typeName": "datasetContactEmail",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ contact.contact_email }}"
                }
              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {
            "typeName": "dsDescription",
            "multiple": true,
            "typeClass": "compound",
            "value": [
              {% for desc in dataset.citation.dataset_description %}
              {
                "dsDescriptionValue": {
                  "typeName": "dsDescriptionValue",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ desc.description }}"
                }
                {% if desc.description_date %},
                "dsDescriptionDate": {
                  "typeName": "dsDescriptionDate",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ desc.description_date }}"
                }
                {% endif %}
              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {
            "typeName": "keyword",
            "multiple": true,
            "typeClass": "compound",
             "value": [
              {% for keyword in dataset.citation.keyword %}
              {
                "keywordValue": {
                  "typeName": "keywordValue",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ keyword.keyword }}"
                }
                {% if keyword.keyword_term_uri %},
                "keywordTermURI": {
                  "typeName": "keywordTermURI",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ keyword.keyword_term_uri }}"
                }
                {% endif %}
                {% if keyword.keyword_vocabulary %},
                "keywordVocabulary": {
                  "typeName": "keywordVocabulary",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ keyword.keyword_vocabulary }}"
                }
                {% endif %}
                {% if keyword.keyword_vocabulary_uri %},
                "keywordVocabularyURI": {
                  "typeName": "keywordVocabularyURI",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ keyword.keyword_vocabulary_uri }}"
                }
                {% endif %}
              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {
            "typeName": "topicClassification",
            "multiple": true,
            "typeClass": "compound",
             "value": [
              {% for topic  in dataset.citation.topic_classification %}
              {
                "topicClassValue": {
                  "typeName": "topicClassValue",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ topic.topic_name }}"
                }
                {% if topic.topic_class_vocab %},
                "topicClassVocab": {
                  "typeName": "topicClassVocab",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ topic.topic_class_vocab }}"
                }
                {% endif %}
                {% if topic.topic_class_vocab_uri %},
                "topicClassVocabURI": {
                  "typeName": "topicClassVocabURI",
                  "multiple": false,
                  "typeClass": "primitive",
                  "value": "{{ topic.topic_class_vocab_uri }}"
                }
                {% endif %}
              }{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {
            "typeName": "subject",
            "multiple": true,
            "typeClass": "controlledVocabulary",
            "value": [
              {% for subject in dataset.citation.subject %}
              "{{ subject }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {
            "typeName": "language",
            "multiple": true,
            "typeClass": "controlledVocabulary",
            "value": [
              {% for language in dataset.citation.language %}
              "{{ language }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {
              "typeName": "publication",
              "multiple": true,
              "typeClass": "compound",
              "value": [
                {% for pub in dataset.citation.publication %}
                {
                  "publicationRelationType": {
                    "typeName": "publicationRelationType",
                    "multiple": false,
                    "typeClass": "controlledVocabulary",
                    "value": "{{ pub.publication_relation_type }}"
                  },
                  "publicationCitation": {
                    "typeName": "publicationCitation",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ pub.citation }}"
                  }
                  {% if pub.id_type %},
                  "publicationIDType": {
                    "typeName": "publicationIDType",
                    "multiple": false,
                    "typeClass": "controlledVocabulary",
                    "value": "{{ pub.id_type }}"
                  }
                  {% endif %}
                  {% if pub.id_number %},
                  "publicationIDNumber": {
                    "typeName": "publicationIDNumber",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ pub.id_number }}"
                  }
                  {% endif %}
                  ,
                  "publicationURL": {
                    "typeName": "publicationURL",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ pub.url }}"
                  }
                }{% if not loop.last %},{% endif %}
                {% endfor %}
              ]
            },
            {
                "typeName": "notesText",
                "multiple": false,
                "typeClass": "primitive",
                "value": "{{ dataset.citation.notes_text }}"
            },
            {
              "typeName": "producer",
              "multiple": true,
              "typeClass": "compound",
              "value": [
                {% for item in dataset.citation.producer %}
                {
                  "producerName": {
                    "typeName": "producerName",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.name }}"
                  },
                  "producerAffiliation": {
                    "typeName": "producerAffiliation",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.affiliation }}"
                  }
                  {% if item.abbreviation %},
                  "producerAbbreviation": {
                    "typeName": "producerAbbreviation",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.abbreviation }}"
                  }
                  {% endif %}
                  ,
                  "producerURL": {
                    "typeName": "producerURL",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.url }}"
                  }
                  {% if item.logo_url %},
                  "producerLogoURL": {
                    "typeName": "producerLogoURL",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.logo_url }}"
                  }
                  {% endif %}
                }{% if not loop.last %},{% endif %}
                {% endfor %}
              ]
            },
            {
                "typeName": "depositor",
                "multiple": false,
                "typeClass": "primitive",
                "value": "{{ dataset.citation.depositor }}"
            },
            {
              "typeName": "timePeriodCovered",
              "multiple": true,
              "typeClass": "compound",
              "value": [
                {% for item in dataset.citation.time_period %}
                {
                  "timePeriodCoveredStart": {
                    "typeName": "timePeriodCoveredStart",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.start }}"
                  },
                  "timePeriodCoveredEnd": {
                    "typeName": "timePeriodCoveredEnd",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.end }}"
                  }
                }{% if not loop.last %},{% endif %}
                {% endfor %}
              ]
            },
            {
              "typeName": "kindOfData",
              "multiple": true,
              "typeClass": "primitive",
              "value": [
                {% for item in dataset.citation.kind_of_data %}
                "{{ item }}"{% if not loop.last %},{% endif %}
                {% endfor %}
              ]
            }
        ]
      },

      "geospatial": {
          "displayName": "Geospatial Metadata",
          "fields": [
            {% if dataset.geospatial.geographic_coverage %}
            {
              "typeName": "geographicCoverage",
              "multiple": true,
              "typeClass": "compound",
              "value": [
                {% for item in dataset.geospatial.geographic_coverage %}
                {
                  {% if item.country %}
                  "country": {
                    "typeName": "country",
                    "multiple": false,
                    "typeClass": "controlledVocabulary",
                    "value": "{{ item.country }}"
                  }
                  {% endif %}
                  {% if item.state %}
                  ,
                  "state": {
                    "typeName": "state",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.state }}"
                  }
                  {% endif %}
                  {% if item.city %}
                  ,
                  "city": {
                    "typeName": "city",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.city }}"
                  }
                  {% endif %}
                  {% if item.other %}
                  ,
                  "otherGeographicCoverage": {
                    "typeName": "otherGeographicCoverage",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.other }}"
                  }
                  {% endif %}
                }{% if not loop.last %},{% endif %}
                {% endfor %}
              ]
            },
            {% endif %}
            {
              "typeName": "geographicUnit",
              "multiple": true,
              "typeClass": "primitive",
              "value": [
                {% for item in dataset.geospatial.geographic_unit %}
                "{{ item }}"{% if not loop.last %},{% endif %}
                {% endfor %}
              ]
            }
            {% if dataset.geospatial.geographic_bounding_box %}
            ,
            {
              "typeName": "geographicBoundingBox",
              "multiple": true,
              "typeClass": "compound",
              "value": [
                {% for item in dataset.geospatial.geographic_bounding_box %}
                {
                  "westLongitude": {
                    "typeName": "westLongitude",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.west }}"
                  },
                  "eastLongitude": {
                    "typeName": "eastLongitude",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.east }}"
                  },
                  "northLatitude": {
                    "typeName": "northLatitude",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.north }}"
                  },
                  "southLatitude": {
                    "typeName": "southLatitude",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ item.south }}"
                  }
                }{% if not loop.last %},{% endif %}
                {% endfor %}
              ]
            }
            {% endif %}
            ]
        },

      "computationalworkflow": {
        "displayName": "Computational Workflow Metadata",
        "fields": [
          {% if dataset.computational_workflow.workflow_type %}
          {
            "typeName": "workflowType",
            "multiple": true,
            "typeClass": "controlledVocabulary",
            "value": [
              {% for item in dataset.computational_workflow.workflow_type %}
              "{{ item }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {% endif %}
          {% if dataset.computational_workflow.workflow_code_repository %}
          {
            "typeName": "workflowCodeRepository",
            "multiple": true,
            "typeClass": "primitive",
            "value": [
              {% for item in dataset.computational_workflow.workflow_code_repository %}
              "{{ item }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          },
          {% endif %}
          {% if dataset.computational_workflow.workflow_documentation %}
          {
            "typeName": "workflowDocumentation",
            "multiple": true,
            "typeClass": "primitive",
            "value": [
              {% for item in dataset.computational_workflow.workflow_documentation %}
              "{{ item }}"{% if not loop.last %},{% endif %}
              {% endfor %}
            ]
          }
          {% endif %}
        ]
      },

      "customCAFEDataLocation": {
          "displayName": "Metadata About Geospatial Files",
          "fields": [
                {
                  "typeName": "cafeIncludesGeospatialFile",
                  "multiple": false,
                  "typeClass": "controlledVocabulary",
                  "value": "{{ dataset.cafe_custom.includes_geospatial_file }}"
                }
            ]
        },

      "customCAFEDataSources": {
        "displayName": "Metadata About Data Sources",
        "fields": [
          {
            "typeName": "cafeDerivedFromExistingDataset",
            "multiple": false,
            "typeClass": "controlledVocabulary",
            "value": "{{ dataset.cafe_custom.derived_from_existing_dataset }}"
          },
          {
              "typeName": "cafeSourceData",
              "multiple": true,
              "typeClass": "compound",
              "value": [
                {% for src in dataset.cafe_custom.source_data %}
                {
                  "cafeSourceDataTitle": {
                    "typeName": "cafeSourceDataTitle",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.title }}"
                  },
                  "cafeSourceDataAuthor": {
                    "typeName": "cafeSourceDataAuthor",
                    "multiple": true,
                    "typeClass": "primitive",
                    "value": [
                      {% for auth in src.authors %}
                      "{{ auth }}"{% if not loop.last %},{% endif %}
                      {% endfor %}
                    ]
                  },
                  "cafeSourceDataInstitution": {
                    "typeName": "cafeSourceDataInstitution",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.institution }}"
                  },
                  "cafeSourceDataVersionNumber": {
                    "typeName": "cafeSourceDataVersionNumber",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.version_number }}"
                  },
                  "cafeSourceDataDOIOrURL": {
                    "typeName": "cafeSourceDataDOIOrURL",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.doi_or_url }}"
                  },
                  "cafeSourceDataLastModifiedDate": {
                    "typeName": "cafeSourceDataLastModifiedDate",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.last_modified_date }}"
                  },
                  "cafeSourceDataDateObtained": {
                    "typeName": "cafeSourceDataDateObtained",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.date_obtained }}"
                  },
                  "cafeSourceDataType": {
                    "typeName": "cafeSourceDataType",
                    "multiple": false,
                    "typeClass": "controlledVocabulary",
                    "value": "{{ src.data_type }}"
                  },
                  "cafeSourceDataTypeOther": {
                    "typeName": "cafeSourceDataTypeOther",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.type_other }}"
                  }
                  {% if src.spatial_resolution %},
                  "cafeSourceDataSpatialResolution": {
                    "typeName": "cafeSourceDataSpatialResolution",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.spatial_resolution }}"
                  }
                  {% endif %}
                  {% if src.spatial_resolution_unit %},
                  "cafeSourceDataSpatialResolutionUnit": {
                    "typeName": "cafeSourceDataSpatialResolutionUnit",
                    "multiple": false,
                    "typeClass": "controlledVocabulary",
                    "value": "{{ src.spatial_resolution_unit }}"
                  }
                  {% endif %}
                  {% if src.spatial_resolution_unit_other %},
                  "cafeSourceDataSpatialResolutionUnitOther": {
                    "typeName": "cafeSourceDataSpatialResolutionUnitOther",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.spatial_resolution_unit_other }}"
                  }
                  {% endif %}
                  {% if src.timestep %},
                  "cafeSourceDataTimestep": {
                    "typeName": "cafeSourceDataTimestep",
                    "multiple": false,
                    "typeClass": "controlledVocabulary",
                    "value": "{{ src.timestep }}"
                  }
                  {% endif %}
                  {% if src.timestep_other %},
                  "cafeSourceDataTimestepOther": {
                    "typeName": "cafeSourceDataTimestepOther",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.timestep_other }}"
                  }
                  {% endif %}
                  {% if src.attribution %},
                  "cafeSourceDataAttribution": {
                    "typeName": "cafeSourceDataAttribution",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.attribution }}"
                  }
                  {% endif %}
                  ,
                  "cafeSourceDataDisclaimer": {
                    "typeName": "cafeSourceDataDisclaimer",
                    "multiple": false,
                    "typeClass": "primitive",
                    "value": "{{ src.disclaimer }}"
                  }
                }{% if not loop.last %},{% endif %}
                {% endfor %}
              ]
          }
        ]
      }
    }

    {% if dataset.files|length > 0 %}
    ,
    "files": [
      {% for file in dataset.files %}
      {
        "description": "{{ file.description }}",
        "label": "{{ file.label }}",
        "restricted": {{ file.restricted | lower }},
        "version": {{ file.version }},
        "datasetVersionId": {{ file.dataset_version_id }},
        "dataFile": {
          "id": {{ file.id }},
          "filename": "{{ file.filename }}",
          "contentType": "{{ file.content_type }}",
          "filesize": {{ file.filesize }},
          "description": "{{ file.description }}",
          "storageIdentifier": "{{ file.storage_identifier }}",
          "originalFormatLabel": "{{ file.original_format_label }}",
          "rootDataFileId": {{ file.root_data_file_id }},
          "checksum": {
            "type": "{{ file.checksum_type }}",
            "value": "{{ file.checksum_value }}"
          }
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
    {% endif %}
  }
}
